# PostgreSQL
POSTGRES_USER=findocint
POSTGRES_PASSWORD=findocint
POSTGRES_DB=findocint
DATABASE_URL=postgresql://findocint:findocint@localhost:5432/findocint

# LLM (claim extraction): Groq primary, Ollama fallback
LLM_PROVIDER=groq                              # groq | ollama
GROQ_API_KEY=gsk-...                           # console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b-instruct

# Embeddings: local bge (768-dim) primary, OpenAI fallback
EMBEDDING_PROVIDER=bge                          # bge | openai
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# OpenAI (embedding fallback + optional hosted judge)
OPENAI_API_KEY=sk-...          # platform.openai.com/api-keys

# Anthropic (optional external tie-breaker judge)
ANTHROPIC_API_KEY=sk-ant-...   # console.anthropic.com

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
API_SECRET_KEY=change-me
